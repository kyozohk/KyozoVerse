
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for community membership
    function isCommunityMember(communityId) {
      return request.auth != null && exists(/databases/$(database)/documents/communityMembers/$(request.auth.uid + '_' + communityId));
    }

    // Helper function to check if user is community owner
    function isCommunityOwner(communityId) {
      return request.auth != null &&
             get(/databases/$(database)/documents/communities/$(communityId)).data.ownerId == request.auth.uid;
    }

    // Helper function to check if user is community admin or owner
    function isCommunityAdmin(communityId) {
      let memberDoc = get(/databases/$(database)/documents/communityMembers/$(request.auth.uid + '_' + communityId));
      return request.auth != null &&
             (memberDoc.data.role == 'owner' || memberDoc.data.role == 'admin');
    }

    // ---- v2 multi-tenant helpers -----------------------------------------
    // A user belongs to a workspace if either:
    //   (a) they own the workspace doc (workspaces/{id}.ownerUid == uid), or
    //   (b) they have an active workspaceMembers record for that workspace.
    // These helpers are intentionally narrow; v2 collections (contacts,
    // imports, sourceConnections) are admin-SDK-only and don't rely on them
    // for client reads, but they're available for narrowly-scoped exceptions.
    function workspaceExists(workspaceId) {
      return exists(/databases/$(database)/documents/workspaces/$(workspaceId));
    }
    function isWorkspaceOwner(workspaceId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerUid == request.auth.uid;
    }
    function belongsToWorkspace(workspaceId) {
      return request.auth != null &&
        (isWorkspaceOwner(workspaceId) ||
         exists(/databases/$(database)/documents/workspaceMembers/$(request.auth.uid + '_' + workspaceId)));
    }

    // Communities can be read by anyone
    match /communities/{communityId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Owners can update everything; any authenticated user can increment memberCount only.
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
      );
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
      
      // Community tags subcollection
      match /tags/{tagId} {
        allow read, write: if request.auth != null;
      }
    }

    // Community members can be read by other members of that same community
    match /communities/{communityId}/members/{memberId} {
        allow read, write: if request.auth != null && request.auth.uid == memberId;
    }

    // Blogs (posts) rules
    match /blogs/{blogId} {
      // Allow LIST queries for public posts by anyone, and for all posts by authenticated users.
      allow list: if true;
      
      // Allow GET requests for public documents, or for the author of a private document.
      allow get: if resource.data.visibility == 'public' || (request.auth != null && request.auth.uid == resource.data.authorId);
      
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      
      allow update, delete: if request.auth != null && 
                               (request.auth.uid == resource.data.authorId || 
                                (resource.data.communityId != null && isCommunityOwner(resource.data.communityId)));

      // Subcollections for likes and comments
      match /likes/{likeId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }
    }
    
    // User interaction collection rules
    match /userInteractions/{interactionId} {
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Users collection can be read by anyone authenticated
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;

      // (1) Users can fully update their own profile.
      // (2) Apple guideline 1.2.1(a) — community operators need to set
      //     `birthYear` on members who pre-date the in-app signup form so
      //     the mobile feed's age-gate has something to compare against.
      //     Any authenticated user may write `birthYear` (and the
      //     bookkeeping `updatedAt`) on another user's doc, but nothing
      //     else. The field-level scope means this rule cannot be abused
      //     to change emails, displayNames, blocked-user lists, etc.
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['birthYear', 'updatedAt'])
      );

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Messages collections
    match /messages_whatsapp/{messageId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    
    // Community members collection
    match /communityMembers/{memberId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null && 
                       (resource.data.userId == request.auth.uid || 
                        isCommunityOwner(resource.data.communityId));
    }

    // Workspace members collection - used for platform-wide roles (admin/community_creator/read_only)
    match /workspaceMembers/{memberId} {
      // NOTE: Without an explicit match block, Firestore denies all access by default.
      // The app reads this collection in `usePlatformRole` and `useAuth`.
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // Guestlists collection - community members can create/read/update guestlists for their community
    match /guestlists/{guestlistId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
                               isCommunityMember(resource.data.communityId);
    }

    // RSVPs collection - community members can read, admins/owners can create/update/delete
    match /rsvps/{rsvpId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                               isCommunityMember(resource.data.communityId);
    }

    // Waitlist collection - allow anyone to submit, only admin to read/update
    match /waitlist/{requestId} {
      allow create: if true; // Anyone can submit a waitlist request
      allow read, update: if request.auth != null && request.auth.token.email == 'dev@kyozo.com'; // Only admin can read/update
    }

    // Inbox messages collection - community members can read messages for their community
    match /inboxMessages/{messageId} {
      allow read: if request.auth != null; // Temporarily allow all authenticated users
      allow create: if true; // Webhook creates messages (no auth)
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // API keys collection - server-only.
    // Only the Firebase Admin SDK (which bypasses these rules) may read or
    // write here. Client SDK access is denied so raw key hashes never leak.
    match /apiKeys/{keyHash} {
      allow read, write: if false;
    }

    // ===================================================================
    // v2 collections — Contact Consolidation Tool / multi-tenant workspaces
    // ===================================================================
    //
    // Default posture for v2 PII-heavy collections is admin-SDK-only.
    // The client SDK is denied across the board; all reads/writes go
    // through server-side API routes that re-check workspace membership
    // in code AND stamp `workspaceId` on every doc.
    //
    // This is intentionally stricter than v1's pattern: a misconfigured
    // client app should not be able to leak 10k contacts.

    // Workspaces themselves: the workspace doc is readable by members
    // (so the dashboard can show its name/branding); writes go through
    // the server.
    match /workspaces/{workspaceId} {
      allow read: if belongsToWorkspace(workspaceId);
      allow write: if false;
    }

    // Contacts — the Master Database. Strict admin-SDK only.
    // A leaked client key reading from here = a 10k-row contact dump,
    // so we keep the client surface zero.
    match /contacts/{contactId} {
      allow read, write: if false;
    }

    // Imports — audit-trail records for every "push to Kyozo".
    // Immutable after creation. Admin-SDK only.
    match /imports/{importId} {
      allow read, write: if false;
    }

    // Source connections — encrypted OAuth tokens for Eventbrite, GSheets,
    // Resident Advisor, 7 Rooms. Even ciphertext never round-trips
    // through client SDKs; reads go through the server which decrypts.
    match /sourceConnections/{connectionId} {
      allow read, write: if false;
    }

    // Community audience — soft tag of a contact into a community.
    // The joined `contacts` doc IS PII, so we keep this admin-SDK-only too.
    // Pages render audience through server routes.
    match /communityAudience/{audienceId} {
      allow read, write: if false;
    }
  }
}
