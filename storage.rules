rules_version = '2';

// =====================================================================
// KyozoVerse Cloud Storage rules — tightened May 2026.
//
// Defaults: deny everything. Explicit `allow` blocks open up specific
// paths only. The Admin SDK bypasses these rules, so server routes
// (e.g. /api/upload, /api/whatsapp/webhook) can still write where the
// client SDK can't.
// =====================================================================
service firebase.storage {
  match /b/{bucket}/o {

    // ---------------------------------------------------------------
    // Posts: each user owns /posts/{uid}/...
    // ---------------------------------------------------------------
    match /posts/{userId}/{allPaths=**} {
      // Public read so post media renders for everyone.
      allow read: if true;
      // Only the user themselves may write to their own folder.
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 100 * 1024 * 1024  // 100 MB cap
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType.matches('audio/.*')
                       || request.resource.contentType.matches('video/.*'));
    }

    // ---------------------------------------------------------------
    // Community media: /community-media/{communityId}/...
    // Members of the community may upload; everyone may read.
    // ---------------------------------------------------------------
    match /community-media/{communityId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && exists(/databases/(default)/documents/communityMembers/$(request.auth.uid + '_' + communityId))
                   && request.resource.size < 100 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType.matches('audio/.*')
                       || request.resource.contentType.matches('video/.*'));
    }

    // ---------------------------------------------------------------
    // User-owned media (avatars, banners): /user-media/{uid}/...
    // ---------------------------------------------------------------
    match /user-media/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ---------------------------------------------------------------
    // WhatsApp media: /whatsapp-media/...
    // Server-only writes (webhook uses Admin SDK). Reads are public so
    // the inbox UI can display media via <img>/<video> src URLs.
    // ---------------------------------------------------------------
    match /whatsapp-media/{allPaths=**} {
      allow read: if true;
      allow write: if false;  // Admin SDK only.
    }

    // Default: deny everything else.
  }
}
